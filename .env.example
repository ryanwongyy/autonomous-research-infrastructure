# APE Replica — Environment Configuration
# Copy to backend/.env and fill in values.

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./ape_replica.db
# DATABASE_URL=postgresql+asyncpg://ape:your_password@localhost:5432/ape_replica

# LLM Provider API Keys (at least one required for paper generation)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Authentication (leave blank to disable auth in dev mode)
APE_API_KEY=
APE_ADMIN_KEY=

# Data Source API Keys (optional — sources degrade gracefully without keys)
REGULATIONS_GOV_API_KEY=
COURTLISTENER_API_KEY=
OPENALEX_EMAIL=

# Artifact storage backend.
#   filesystem (default) — local disk; fine for dev/tests, ephemeral on Render.
#   s3                   — any S3-compatible store (R2, Supabase, B2, AWS S3).
# When using s3, fill in the S3_* keys below. Requires `pip install -e .[cloud]`.
ARTIFACT_STORE_BACKEND=filesystem

# Required only when ARTIFACT_STORE_BACKEND=s3
S3_BUCKET=
S3_ENDPOINT_URL=        # leave blank for AWS S3; set for R2/Supabase/B2
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ARTIFACT_PREFIX=artifacts

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000"]

# Docker Compose only
POSTGRES_PASSWORD=change_me_in_production
