# APE Replica — Environment Configuration
# Copy to backend/.env and fill in values.

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./ape_replica.db
# DATABASE_URL=postgresql+asyncpg://ape:your_password@localhost:5432/ape_replica

# LLM Provider API Keys (at least one required for paper generation)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Authentication (leave blank to disable auth in dev mode)
APE_API_KEY=
APE_ADMIN_KEY=

# Data Source API Keys
# In DATA_MODE=real (the default), at least one source must be reachable for
# the family being generated, or the pipeline will hard-fail. In permissive
# mode the sources are optional and missing keys trigger synthetic data.
REGULATIONS_GOV_API_KEY=
COURTLISTENER_API_KEY=
OPENALEX_EMAIL=

# Data fetching mode for the paper-generation pipeline.
#   real       — strict: hard-fail if any source can't return real data.
#                Default; required for production. Papers' claims must be
#                grounded in actual fetched sources.
#   permissive — allow synthetic placeholder CSV when no source returns
#                data. Local-dev only. Papers produced this way are NOT
#                grounded in real data and MUST NOT be released publicly.
DATA_MODE=real

# Cost guardrails (Step 5).
# COST_TRACKING_ENABLED=False disables the whole subsystem (no LLMSpend rows
# written, no caps enforced) — only useful for offline testing. Set caps to
# 0 to disable an individual check while leaving the ledger on.
COST_TRACKING_ENABLED=True
MAX_SPEND_PER_PAPER_USD=50.0
MAX_DAILY_SPEND_USD=200.0

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000"]

# Docker Compose only
POSTGRES_PASSWORD=change_me_in_production
