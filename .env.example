# APE Replica — Environment Configuration
# Copy to backend/.env and fill in values.

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./ape_replica.db
# DATABASE_URL=postgresql+asyncpg://ape:your_password@localhost:5432/ape_replica

# LLM Provider API Keys (at least one required for paper generation)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# LLM model IDs.
# Defaults match the publicly documented latest ids as of 2026-04. Override
# via env vars when a new dated suffix ships, or to point at a different
# tier (e.g. CLAUDE_OPUS_MODEL=claude-opus-4-5-20250119 to pin a snapshot).
CLAUDE_OPUS_MODEL=claude-opus-4-5
CLAUDE_SONNET_MODEL=claude-sonnet-4-5
CLAUDE_HAIKU_MODEL=claude-haiku-4-5
OPENAI_MAIN_MODEL=gpt-4o
OPENAI_REASONING_MODEL=o1
OPENAI_FAST_MODEL=gpt-4o-mini
JUDGE_NON_CLAUDE_MODEL=gpt-4o
GOOGLE_MAIN_MODEL=gemini-1.5-pro

# Authentication (leave blank to disable auth in dev mode)
APE_API_KEY=
APE_ADMIN_KEY=

# Data Source API Keys (optional — sources degrade gracefully without keys)
REGULATIONS_GOV_API_KEY=
COURTLISTENER_API_KEY=
OPENALEX_EMAIL=

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000"]

# Docker Compose only
POSTGRES_PASSWORD=change_me_in_production
