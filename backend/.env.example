# ── Core ────────────────────────────────────────────────────────────
APP_NAME=APE Replica
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./ape_replica.db

# ── LLM API Keys ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Domain ─────────────────────────────────────────────────────────
DEFAULT_DOMAIN=ai_governance

# ── Tournament ─────────────────────────────────────────────────────
TOURNAMENT_MATCHES_PER_DAY=50
TOURNAMENT_BATCHES=10
TOURNAMENT_MATCHES_PER_BATCH=5
TOURNAMENT_SCHEDULE_HOUR=9
TOURNAMENT_SCHEDULE_MINUTE=0

# ── TrueSkill ──────────────────────────────────────────────────────
TRUESKILL_MU=25.0
TRUESKILL_SIGMA=8.333
TRUESKILL_BETA=4.167
TRUESKILL_TAU=0.083
TRUESKILL_DRAW_PROBABILITY=0.1

# ── Elo ────────────────────────────────────────────────────────────
ELO_DEFAULT=1500.0
ELO_K_FACTOR=32.0

# ── Storage & Paths ────────────────────────────────────────────────
PAPERS_DIR=papers
ARTIFACT_STORE_PATH=artifacts
DOMAIN_CONFIGS_DIR=domain_configs

# ── Enforcement ────────────────────────────────────────────────────
LOCK_ENFORCEMENT=hard
SOURCE_STALE_DAYS=90
DRIFT_THRESHOLD=0.8

# ── Authentication ─────────────────────────────────────────────
APE_API_KEY=
APE_ADMIN_KEY=

# ── Data Source API Keys (optional) ───────────────────────────
REGULATIONS_GOV_API_KEY=
COURTLISTENER_API_KEY=
OPENALEX_EMAIL=

# ── Monitoring ─────────────────────────────────────────────────
SENTRY_DSN=

# ── CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
